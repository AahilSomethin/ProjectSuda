{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "elevenlabs-tts",
    "opener:default",
    "core:window:allow-close",
    "core:window:allow-set-position",
    "core:window:allow-current-monitor",
    "core:window:allow-inner-size"
  ]
}
