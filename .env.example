# Character GIF (served from public/)
VITE_CHARACTER_GIF_URL=/suda.gif

# OpenAI summary engine (optional — mocked summary used when empty)
# TODO: Frontend API key is okay for local dev only. Use a backend proxy before shipping to users.
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-4o-mini

# Linear integration (optional for MVP — mocks used when empty)
VITE_LINEAR_API_KEY=
VITE_LINEAR_TEAM_ID=

# Google Calendar integration — disabled for now
# VITE_GOOGLE_CALENDAR_API_KEY=
# VITE_GOOGLE_CALENDAR_ID=

# ElevenLabs voice for SUDA TTS. Browser speechSynthesis is fallback only.
# Read by the Tauri backend — do NOT prefix with VITE_.
# Restart `npm run tauri dev` after changing these values.
# Voice debug logs: Tauri terminal (Rust) + webview devtools console ([SUDA] prefix).
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id_here
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.75
ELEVENLABS_STYLE=0
ELEVENLABS_USE_SPEAKER_BOOST=true
